<section id="tow-combat-overlay-top-panel" class="tow-combat-overlay-top-panel" aria-label="Scene tokens panel" data-has-tokens="false">
  <div class="tow-combat-overlay-top-panel__controls" aria-label="Top panel controls">
    <button
      type="button"
      class="tow-combat-overlay-top-panel__control-button tow-combat-overlay-top-panel__control-button--lock"
      data-action="toggle-panel-drag-lock"
      aria-pressed="true"
      aria-label="Lock panel movement"
    >
      <span class="tow-combat-overlay-top-panel__control-toggle-icon">U</span>
    </button>
    <button
      type="button"
      class="tow-combat-overlay-top-panel__control-button tow-combat-overlay-top-panel__control-button--reset"
      data-action="reset-panel-position"
      aria-label="Reset top panel position"
    >
      R
    </button>
  </div>
  <div class="tow-combat-overlay-top-panel__list" role="list" aria-live="polite"></div>
</section>
