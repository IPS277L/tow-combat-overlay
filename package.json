{
  "name": "tow-combat-overlay",
  "private": true,
  "version": "0.0.0",
  "description": "Linting and quality tooling for the Foundry module",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,json,md,yml,yaml,css}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix"
    ]
  }
}
